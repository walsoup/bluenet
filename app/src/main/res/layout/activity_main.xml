<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- App Title Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_launcher_foreground"
                android:background="@color/primary"
                android:padding="4dp"
                android:contentDescription="App Logo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#0D47A1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_tagline"
                    android:textSize="12sp"
                    android:textColor="#555555"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Mode Selector Radio Buttons -->
        <RadioGroup
            android:id="@+id/rgModeSelector"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:checkedButton="@id/rbClientMode"
            android:background="#E0E0E0"
            android:padding="2dp"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rbClientMode"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:button="@null"
                android:background="#1E88E5"
                android:gravity="center"
                android:text="@string/tab_client"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <RadioButton
                android:id="@+id/rbHostMode"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:button="@null"
                android:background="#E0E0E0"
                android:gravity="center"
                android:text="@string/tab_host"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </RadioGroup>

        <!-- HOST PANEL -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Host Mode (Tether Provider)"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#0D47A1"/>

                <TextView
                    android:id="@+id/tvHostStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/status_offline"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginTop="8dp"/>

                <!-- Host MAC and PSM Container -->
                <LinearLayout
                    android:id="@+id/layoutMacContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#E3F2FD"
                    android:padding="16dp"
                    android:visibility="gone"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/host_mac_label"
                        android:textSize="12sp"
                        android:textColor="#0D47A1"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvHostMac"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AA:BB:CC:DD:EE:FF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#002171"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/tvHostPsm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PSM: 12345"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#002171"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToggleHost"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="@string/btn_start_host"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#0D47A1"
                    app:cornerRadius="8dp"
                    android:layout_marginTop="20dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CLIENT PANEL -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardClient"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Client Mode (Tether Receiver)"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#0D47A1"/>

                <!-- MAC Address Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/enter_mac_label"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginTop="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <EditText
                        android:id="@+id/etMacAddress"
                        android:layout_width="0dp"
                        android:layout_weight="2"
                        android:layout_height="48dp"
                        android:hint="AA:BB:CC:DD:EE:FF"
                        android:textColorHint="#999999"
                        android:textColor="#000000"
                        android:textSize="15sp"
                        android:inputType="textCapCharacters"
                        android:background="@android:drawable/editbox_background"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>

                    <EditText
                        android:id="@+id/etPsm"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:hint="PSM"
                        android:textColorHint="#999999"
                        android:textColor="#000000"
                        android:textSize="15sp"
                        android:inputType="number"
                        android:background="@android:drawable/editbox_background"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <!-- Or Dropdown Selector -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/select_device_label"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginTop="16dp"/>

                <Spinner
                    android:id="@+id/spDevices"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@android:drawable/btn_dropdown"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/tvClientStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/status_offline"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginTop="16dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToggleClient"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="@string/btn_connect_mac"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#1E88E5"
                    app:cornerRadius="8dp"
                    android:layout_marginTop="20dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
